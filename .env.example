# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Server only. Never prefix this with VITE_.
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# ─── Billing phase 1: development mock checkout ─────────────────────────────
# Must remain false/unset in production. The server also rejects mocks when
# NODE_ENV=production or CF_PAGES_BRANCH=main.
ENABLE_MOCK_PAYMENTS=true
APPLICATION_URL=http://localhost:5173

# ─── Billing phase 2: ToyyibPay sandbox/live ────────────────────────────────
TOYYIBPAY_API_URL=https://dev.toyyibpay.com
TOYYIBPAY_CATEGORY_CODE=your-sandbox-category-code
TOYYIBPAY_SECRET_KEY=your-server-only-sandbox-secret

# ─── Transactional invoices (server only) ──────────────────────────────────
RESEND_API_KEY=re_your_server_only_key
INVOICE_SENDER_EMAIL=AcadeMY Billing <billing@example.com>
ACADEMY_LEGAL_NAME=AcadeMY [Legal company name]
ACADEMY_SSM_NUMBER=[Registration number]
ACADEMY_BUSINESS_ADDRESS=[Business address]

# ─── Setup Instructions ───────────────────────────────────────────────────────
# 1. Create a free Supabase project at https://supabase.com
# 2. Copy your Project URL and anon/public key from Settings → API
# 3. Apply the migrations in supabase/migrations (or run `npx supabase db push`)
# 4. Enable Google OAuth in Supabase Auth → Providers → Google
# 5. Add your Google Cloud OAuth credentials (Client ID + Secret)
# 6. Add your site URL to Supabase Auth → URL Configuration → Redirect URLs
#    e.g. http://localhost:5173, https://your-app.pages.dev
# 7. Put VITE_ values in .env.local and server-only values in .dev.vars.
#    Both files are ignored by Git; never commit real values.
